# ─────────────────────────────────────────────────────────────────────────────
# TravelPulse India — Environment Configuration
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL + Prisma ORM)
# ═══════════════════════════════════════════════════════════════════════════════

# Primary connection string (used by Prisma Client at runtime)
# For Supabase/Neon: Use the pooled connection string (port 6543)
DATABASE_URL="postgresql://user:password@localhost:5432/travelpulse_india?schema=public"

# Direct connection string (used by Prisma Migrate for DDL operations)
# For Supabase/Neon: Use the direct connection string (port 5432)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/travelpulse_india?schema=public"

# ═══════════════════════════════════════════════════════════════════════════════
# NEXT.JS APPLICATION
# ═══════════════════════════════════════════════════════════════════════════════

# App URL (used for canonical URLs, OG images, sitemap generation)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# App environment
NODE_ENV="development"

# ═══════════════════════════════════════════════════════════════════════════════
# AI / LLM — DeepSeek API (News Categorization & Summarization)
# ═══════════════════════════════════════════════════════════════════════════════

# DeepSeek API key for AI-powered news categorization, sentiment analysis,
# and smart summary generation
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"

# DeepSeek model to use (default: deepseek-chat)
DEEPSEEK_MODEL="deepseek-chat"

# DeepSeek API base URL
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/v1"

# ═══════════════════════════════════════════════════════════════════════════════
# RSS / NEWS FETCHING
# ═══════════════════════════════════════════════════════════════════════════════

# Maximum number of articles to fetch per source per cycle
RSS_MAX_ARTICLES_PER_SOURCE=25

# Fetch interval in seconds (default: 3600 = 1 hour)
RSS_FETCH_INTERVAL_SECONDS=3600

# User-Agent header for RSS requests
RSS_USER_AGENT="TravelPulse-India/1.0 (+https://travelpulse.in)"

# ═══════════════════════════════════════════════════════════════════════════════
# CRON / SCHEDULED JOBS (node-cron)
# ═══════════════════════════════════════════════════════════════════════════════

# Enable or disable background cron jobs
CRON_ENABLED="true"

# Cron expression for RSS fetching (default: every 30 minutes)
CRON_RSS_FETCH="*/30 * * * *"

# Cron expression for AI categorization (default: every 15 minutes)
CRON_AI_CATEGORIZE="*/15 * * * *"

# Cron expression for exchange rate updates (default: every 6 hours)
CRON_EXCHANGE_RATES="0 */6 * * *"

# Cron expression for daily fact rotation (default: midnight IST)
CRON_DAILY_FACT="30 18 * * *"

# ═══════════════════════════════════════════════════════════════════════════════
# EXCHANGE RATE API
# ═══════════════════════════════════════════════════════════════════════════════

# Exchange rate API key (exchangerate-api.com or similar)
EXCHANGE_RATE_API_KEY="your-exchange-rate-api-key-here"

# Base currency for exchange rates
EXCHANGE_RATE_BASE_CURRENCY="INR"

# ═══════════════════════════════════════════════════════════════════════════════
# IMAGE / MEDIA STORAGE
# ═══════════════════════════════════════════════════════════════════════════════

# Cloudinary (or similar) for article cover images and media assets
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ═══════════════════════════════════════════════════════════════════════════════
# ANALYTICS & MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Vercel Analytics (automatically enabled on Vercel deployment)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Sentry for error tracking (optional)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ═══════════════════════════════════════════════════════════════════════════════
# SEO & SOCIAL
# ═══════════════════════════════════════════════════════════════════════════════

# Default SEO metadata
NEXT_PUBLIC_SITE_NAME="TravelPulse India"
NEXT_PUBLIC_SITE_DESCRIPTION="India's Premier Travel News Aggregation Platform — Visa Updates, Travel Advisories, Government Initiatives & Daily Tourism Facts"

# Social media links (for structured data and footer)
NEXT_PUBLIC_TWITTER_HANDLE="@TravelPulseIN"
NEXT_PUBLIC_INSTAGRAM_HANDLE="@travelpulseindia"

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY & RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════════

# API rate limiting (requests per minute per IP)
API_RATE_LIMIT_RPM=60

# Internal API secret for cron job endpoints
CRON_SECRET="your-cron-secret-key-here"

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT — VERCEL
# ═══════════════════════════════════════════════════════════════════════════════

# Vercel deployment settings (auto-populated by Vercel)
# VERCEL_URL is automatically set during deployment
# VERCEL_ENV is automatically set (production | preview | development)
